{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@latest", "opencode-mem@latest"],
  "provider": {
    "volcengine-plan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Volcano Engine",
      "options": {
        "baseURL": "https://ark.cn-beijing.volces.com/api/coding/v3",
        "apiKey": "{env:VOLC_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash",
          "limit": { "context": 1000000, "output": 384000 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "deepseek-v4-pro": {
          "name": "deepseek-v4-pro",
          "limit": { "context": 1000000, "output": 384000 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "doubao-seed-2.0-code": {
          "name": "doubao-seed-2.0-code",
          "limit": { "context": 256000, "output": 32768 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "doubao-seed-2.0-lite": {
          "name": "doubao-seed-2.0-lite",
          "limit": { "context": 256000, "output": 32768 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "doubao-seed-2.0-pro": {
          "name": "doubao-seed-2.0-pro",
          "limit": { "context": 256000, "output": 65536 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "glm-5.2": {
          "name": "glm-5.2",
          "limit": { "context": 1024000, "output": 131072 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "kimi-k2.6": {
          "name": "kimi-k2.6",
          "limit": { "context": 256000, "output": 32768 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "minimax-m3": {
          "name": "minimax-m3",
          "limit": { "context": 800000, "output": 131072 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "options": {
            "thinking": { "type": "enabled", "budgetTokens": 16384 }
          }
        }
      }
    }
  },
  "mcp": {
    "zai-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "environment": {
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}",
        "Z_AI_MODE": "ZHIPU"
      }
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      }
    },
    "web-reader": {
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      }
    },
    "zread": {
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      }
    },
    "notion": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.notion.com/mcp"]
    },
    "mermaid": {
      "type": "local",
      "command": ["claude-mermaid"]
    },
    "chrome-mcp": {
      "type": "remote",
      "url": "http://127.0.0.1:12306/mcp",
      "enabled": false
    },
    "codegraph": {
      "type": "local",
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true
    }
  },
  "lsp": true,
  "default_agent": "build",
  "share": "manual",
  "autoupdate": "notify",
  "compaction": {
    "auto": true
  },
  "small_model": "volcengine-plan/deepseek-v4-flash",
  "tool_output": {
    "max_lines": 2000,
    "max_bytes": 524288
  },
  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 1600,
      "max_height": 1600
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".next/**",
      "target/**",
      "build/**",
      ".turbo/**",
      ".cache/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      ".mypy_cache/**",
      ".pytest_cache/**",
      ".ruff_cache/**",
      "bin/**",
      "obj/**",
      "DerivedData/**",
      "vendor/**",
      "Pods/**",
      ".gradle/**",
      "coverage/**",
      "tmp/**",
      ".sveltekit/**",
      ".dart_tool/**"
    ]
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.example": "allow",
      "*.env.*": "deny",
      "**/credentials*": "deny",
      "**/secrets*": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "**/id_rsa*": "deny",
      "**/id_ed25519*": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny"
    },
    "bash": {
      "*": "allow",
      "rm -rf*": "deny",
      "rm -fr*": "deny",
      "sudo*": "deny",
      "mkfs*": "deny",
      "shutdown*": "deny",
      "reboot*": "deny",
      "kill*": "deny",
      "pkill*": "deny",
      "killall*": "deny",
      "chmod*": "deny",
      "chown*": "deny",
      "dd*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "git clean*": "deny",
      "git checkout --*": "deny",
      "git checkout .": "deny",
      "git restore --*": "deny",
      "git restore .": "deny",
      "npm publish*": "deny",
      "docker*": "deny",
      "curl * | *sh*": "deny",
      "wget * | *sh*": "deny",
      "eval *": "deny",
      "eval(*": "deny",
      ": > **/.env*": "deny",
      ": > ~/.ssh/*": "deny",
      ": > ~/.aws/*": "deny",
      "git push * --force*": "deny",
      "git push * -f *": "deny",
      "rm -r -f*": "deny",
      "rm -f -r*": "deny",
      "rm -r*f*": "deny",
      "rm -f*r*": "deny",
      ": > ~/.zshrc": "deny",
      ": > ~/.bashrc": "deny",
      ": > ~/.profile": "deny",
      ": > ~/.zshenv": "deny",
      "*> ~/.zshrc": "deny",
      "*> ~/.bashrc": "deny",
      "*>> ~/.zshrc*": "deny",
      "*>> ~/.bashrc*": "deny",
      "tee ~/.zshrc*": "deny",
      "tee ~/.bashrc*": "deny"
    }
  }
}
