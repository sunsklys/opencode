{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/v4.18.1/assets/oh-my-opencode.schema.json",
  "hashline_edit": true,
  "i18n": {
    "locale": "zh"
  },
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "tmux_visualization": false,
    "max_messages_per_run": 10000,
    "max_wall_clock_minutes": 120,
    "max_member_turns": 500,
    "message_payload_max_bytes": 32768,
    "recipient_unread_max_bytes": 262144,
    "mailbox_poll_interval_ms": 3000
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 4,
    "cooldown_seconds": 30,
    "timeout_seconds": 60,
    "notify_on_fallback": true
  },
  "model_fallback": true,
  "model_capabilities": {
    "enabled": true,
    "auto_refresh_on_start": true,
    "refresh_timeout_ms": 5000
  },
  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "volcengine-plan": 5,
      "zhipuai-coding-plan": 5
    },
    "modelConcurrency": {
      "volcengine-plan/deepseek-v4-pro": 3,
      "volcengine-plan/deepseek-v4-flash": 5,
      "volcengine-plan/kimi-k2.6": 3,
      "volcengine-plan/doubao-seed-2.0-pro": 3,
      "volcengine-plan/doubao-seed-2.0-code": 3,
      "volcengine-plan/doubao-seed-2.0-lite": 5,
      "volcengine-plan/minimax-m3": 3,
      "volcengine-plan/glm-5.2": 5,
      "zhipuai-coding-plan/glm-5.2": 5,
      "zhipuai-coding-plan/glm-5-turbo": 3,
      "zhipuai-coding-plan/glm-5v-turbo": 3
    }
  },
  "experimental": {
    "task_system": true,
    "preemptive_compaction": true,
    "aggressive_truncation": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "session_read",
        "session_write",
        "session_search"
      ],
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false },
        "purge_errors": { "enabled": true, "turns": 5 }
      }
    }
  },
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true,
    "tdd": true
  },
  "default_mode": {
    "ultrawork": false,
    "ralph_loop": false
  },
  "agents": {
    "sisyphus": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/glm-5.2",
        "volcengine-plan/kimi-k2.6",
        "volcengine-plan/doubao-seed-2.0-pro"
      ],
      "compaction": { "model": "volcengine-plan/deepseek-v4-flash" }
    },
    "prometheus": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/glm-5.2",
        "volcengine-plan/kimi-k2.6",
        "volcengine-plan/doubao-seed-2.0-pro"
      ],
      "compaction": { "model": "volcengine-plan/deepseek-v4-flash" }
    },
    "plan": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/glm-5.2",
        "volcengine-plan/kimi-k2.6",
        "volcengine-plan/doubao-seed-2.0-pro"
      ],
      "compaction": { "model": "volcengine-plan/deepseek-v4-flash" }
    },
    "oracle": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/glm-5.2",
        "volcengine-plan/kimi-k2.6",
        "volcengine-plan/doubao-seed-2.0-pro"
      ],
      "compaction": { "model": "volcengine-plan/deepseek-v4-flash" }
    },
    "metis": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/glm-5.2",
        "volcengine-plan/kimi-k2.6",
        "volcengine-plan/doubao-seed-2.0-pro"
      ],
      "compaction": { "model": "volcengine-plan/deepseek-v4-flash" }
    },
    "momus": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/glm-5.2",
        "volcengine-plan/kimi-k2.6",
        "volcengine-plan/doubao-seed-2.0-pro"
      ],
      "compaction": { "model": "volcengine-plan/deepseek-v4-flash" }
    },
    "atlas": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/deepseek-v4-pro",
        "volcengine-plan/minimax-m3",
        "volcengine-plan/doubao-seed-2.0-code"
      ],
      "compaction": { "model": "volcengine-plan/deepseek-v4-flash" }
    },
    "librarian": {
      "model": "volcengine-plan/deepseek-v4-flash",
      "reasoningEffort": "medium",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5-turbo",
        "volcengine-plan/doubao-seed-2.0-lite"
      ],
      "textVerbosity": "low"
    },
    "explore": {
      "model": "volcengine-plan/deepseek-v4-flash",
      "reasoningEffort": "medium",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5-turbo",
        "volcengine-plan/doubao-seed-2.0-lite"
      ],
      "textVerbosity": "low"
    },
    "multimodal-looker": {
      "model": "zhipuai-coding-plan/glm-5v-turbo",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/minimax-m3",
        "volcengine-plan/doubao-seed-2.0-code"
      ]
    },
    "sisyphus-junior": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/deepseek-v4-pro",
        "volcengine-plan/minimax-m3",
        "volcengine-plan/doubao-seed-2.0-code"
      ],
      "compaction": { "model": "volcengine-plan/deepseek-v4-flash" }
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "zhipuai-coding-plan/glm-5v-turbo",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/minimax-m3",
        "volcengine-plan/doubao-seed-2.0-code"
      ]
    },
    "ultrabrain": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/glm-5.2",
        "volcengine-plan/kimi-k2.6",
        "volcengine-plan/doubao-seed-2.0-pro"
      ]
    },
    "artistry": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "temperature": 0.7,
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/deepseek-v4-pro",
        "volcengine-plan/minimax-m3",
        "volcengine-plan/doubao-seed-2.0-code"
      ]
    },
    "deep": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/glm-5.2",
        "volcengine-plan/kimi-k2.6",
        "volcengine-plan/doubao-seed-2.0-pro"
      ]
    },
    "quick": {
      "model": "volcengine-plan/deepseek-v4-flash",
      "reasoningEffort": "minimal",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5-turbo",
        "volcengine-plan/doubao-seed-2.0-lite"
      ]
    },
    "unspecified-low": {
      "model": "volcengine-plan/deepseek-v4-flash",
      "reasoningEffort": "low",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5-turbo",
        "volcengine-plan/doubao-seed-2.0-lite"
      ]
    },
    "unspecified-high": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "variant": "high",
      "reasoningEffort": "max",
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/deepseek-v4-pro",
        "volcengine-plan/minimax-m3",
        "volcengine-plan/doubao-seed-2.0-code"
      ]
    },
    "writing": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "temperature": 0.7,
      "prompt_append": "file://.opencode/lang-zh.md",
      "fallback_models": [
        "volcengine-plan/glm-5.2",
        "volcengine-plan/kimi-k2.6",
        "volcengine-plan/doubao-seed-2.0-pro"
      ]
    }
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "disabled_hooks": [
    "auto-update-checker"
  ],
  "keyword_detector": {
    "enabled_expansions": ["ultrawork", "team", "hyperplan", "hyperplan-ultrawork"]
  },
  "monitor": {
    "enabled": true,
    "live_mode_enabled": false,
    "max_monitors_per_session": 3,
    "max_runtime_ms": 1800000,
    "batch_max_lines": 50,
    "batch_max_bytes": 16384,
    "flush_interval_ms": 1000,
    "ring_max_lines": 1000,
    "line_max_bytes": 8192,
    "pattern_max_length": 512
  },
  "ralph_loop": {
    "enabled": false,
    "default_max_iterations": 30,
    "default_strategy": "continue"
  },
  "babysitting": {
    "timeout_ms": 300000
  },
  "comment_checker": {
    "custom_prompt": "检查中文注释与代码一致性。中文注释需准确描述代码行为，避免英文直译凑数。检查：1) 中文表述是否符合代码实际逻辑；2) 是否有 AI 生成的空洞描述（如“这里做一些处理”）；3) 函数/类/复杂分支是否有中文文档注释。代码注释：{{comments}}"
  },
  "disabled_skills": [
    "playwright",
    "dev-browser",
    "agent-browser"
  ],
  "disabled_commands": [
    "ralph-loop",
    "cancel-ralph"
  ]
}
