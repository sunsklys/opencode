{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [429, 500, 502, 503, 504],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "agents": {
    "sisyphus": {
      "model": "volcengine-plan/kimi-k2.6",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5.1",
        "volcengine-plan/deepseek-v4-pro",
        "volcengine-plan/minimax-m3"
      ]
    },
    "hephaestus": {
      "model": "volcengine-plan/deepseek-v4-pro",
      "allow_non_gpt_model": true,
      "fallback_models": [
        "volcengine-plan/minimax-m3",
        "zhipuai-coding-plan/glm-5.1",
        "volcengine-plan/kimi-k2.6"
      ]
    },
    "prometheus": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "volcengine-plan/deepseek-v4-pro",
        "volcengine-plan/minimax-m3",
        "volcengine-plan/kimi-k2.6"
      ]
    },
    "oracle": {
      "model": "volcengine-plan/deepseek-v4-pro",
      "fallback_models": [
        "volcengine-plan/minimax-m3",
        "zhipuai-coding-plan/glm-5.1",
        "volcengine-plan/kimi-k2.6"
      ]
    },
    "metis": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "volcengine-plan/kimi-k2.6",
        "volcengine-plan/deepseek-v4-pro",
        "volcengine-plan/minimax-m2.7"
      ]
    },
    "momus": {
      "model": "volcengine-plan/kimi-k2.6",
      "fallback_models": [
        "volcengine-plan/deepseek-v4-pro",
        "volcengine-plan/minimax-m3",
        "zhipuai-coding-plan/glm-5.1"
      ]
    },
    "atlas": {
      "model": "zhipuai-coding-plan/glm-5.1",
