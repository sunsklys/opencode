# opencode 环境变量模板
# ====================================
# 用法：
#   1. 复制本文件为 .env: cp .env.example .env
#   2. 填入真实 API key
#   3. 加载到 shell:
#        - bash/zsh: 在 ~/.zshrc 末尾添加: set -a; source ~/.config/opencode/.env; set +a
#        - 或临时: set -a && source .env && set +a
#   4. 重启终端 / 重新打开 opencode
#
# ⚠️ .env 已被 .gitignore 排除，绝对不要提交！
# ====================================

# 火山引擎 Ark API (volcengine-plan provider)
# 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
VOLC_API_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 智谱 AI Z.AI API (MCP 服务 zai-mcp-server / Coding Plan 通用)
# 获取地址: https://www.bigmodel.cn/usercenter/apikeys
Z_AI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx
